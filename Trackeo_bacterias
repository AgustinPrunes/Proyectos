%% Rose Plot total

clear
clc

% 1. Lista de archivos
archivos = {'angulos.mat', 'angulos2.mat', 'angulos3.mat'};

% 2. Inicializar acumuladores de pasos crudos
Total_dx = [];
Total_dy = [];

% 3. Cargar y concatenar vectores
for k = 1:length(archivos)
    if isfile(archivos{k})
        datos = load(archivos{k});

        % Verificamos si existen las variables crudas
        if isfield(datos, 'dx_all') && isfield(datos, 'dy_all')
            % Forzamos que sean columnas con (:), así no importa si
            % se guardaron como fila o columna, siempre se pegan bien abajo.
            dx_temp = datos.dx_all(:);
            dy_temp = datos.dy_all(:);

            % Concatenar a la lista maestra
            Total_dx = [Total_dx; dx_temp];
            Total_dy = [Total_dy; dy_temp];

            fprintf('Archivo %s: Cargados %d pasos instantáneos.\n', ...
                archivos{k}, length(dx_temp));
        else
            warning('El archivo %s no tiene "dx_all" o "dy_all". Se salta.', archivos{k});
        end
    else
        warning('Archivo %s no encontrado.', archivos{k});
    end
end

%% 4. Cálculos Globales (Recalculando todo desde cero)

if ~isempty(Total_dx)
    % A) Calcular todos los ángulos de nuevo (en Radianes)
    % atan2 es mejor que atan porque maneja los 4 cuadrantes correctamente
    Angulos_Globales = atan2(Total_dy, Total_dx);

    % B) Calcular Eficiencia Global Ponderada
    % Sumamos todo lo que se avanzó (neto) y dividimos por el esfuerzo total
    Suma_Neta_X = sum(Total_dx);
    Suma_Absoluta_X = sum(abs(Total_dx));

    Eficiencia = Suma_Neta_X / Suma_Absoluta_X;

    %% 5. Generar Gráfico
    figure(21), clf

    % polarhistogram espera Radianes por defecto, así que le pasamos directo.
    % 36 bins = cortes cada 10 grados
    p = polarhistogram(Angulos_Globales, 36);

    % Estética
    p.FaceColor = [0.8500 0.3250 0.0980]; % Naranja rojizo para destacar
    p.FaceAlpha = 0.7;
    p.EdgeColor = 'none'; % Sin bordes negros para que se vea más limpio
    conteo_original = p.BinCounts;
    bordes = p.BinEdges;
    centros = (bordes(1:end-1) + bordes(2:end))/2;

    % Calculamos el "piso de ruido".
    % Asumimos que la dirección con MENOS flujo representa el ruido base isotrópico.
    ruido_isotropico = min(conteo_original);

    % Restamos ese círculo a todos (lo que queda es el exceso direccional puro)
    conteo_rectificado = conteo_original - ruido_isotropico;

    % Como polarhistogram a veces es mañoso para plotear conteos directos,
    % usamos polarplot cerrando el círculo manualmente.
    angulos_plot = [centros, centros(1)]; % Repetir el primero para cerrar
    valores_plot = [conteo_rectificado, conteo_rectificado(1)];

    polarplot(angulos_plot, valores_plot, 'LineWidth', 2, 'Color', [0.8 0.2 0.2])
    hold on
    title('Distribución de Flujo (Global Combinado)')

    % Diagnóstico de color para el texto
    if Eficiencia > 0
        texto_res = sprintf('Rectificación POSITIVA (Derecha): %.4f', Eficiencia);
        col_txt = [0 0.5 0]; % Verde oscuro
    elseif Eficiencia < 0
        texto_res = sprintf('Rectificación NEGATIVA (Izquierda): %.4f', Eficiencia);
        col_txt = [0.8 0 0]; % Rojo oscuro
    else
        texto_res = 'Sin Rectificación (0.0000)';
        col_txt = 'k';
    end

    subtitle(texto_res, 'Color', col_txt, 'FontWeight', 'bold', 'FontSize', 12);

    % Configurar la grilla polar para que sea más legible
    rlim([0 max(p.Values)*1.1]); % Dar un poco de aire al borde

    fprintf('\n=== REPORTE FINAL ===\n');
    fprintf('Total de pasos analizados: %d\n', length(Total_dx));
    fprintf('Eficiencia Calculada:      %.5f\n', Eficiencia);

else
    error('No se pudieron cargar datos. Revisa que tus .mat tengan "dx_all" y "dy_all".');
end

%% Rose Plot Avanzado: Filtro de Ruido (Time Lag + Sustracción Isotrópica)
% REQUISITO: Necesitas tener cargada la variable 'track' en el Workspace.

% --- PARÁMETRO DE AJUSTE ---
% Lag: Cuantos frames saltar.
% Lag = 1 es lo que tenías antes (mucho ruido).
% Lag = 5 o 10 suele ser ideal para ver rectificación real.
Lag = 7;

dx_lagged = [];
dy_lagged = [];

% 1. Calcular desplazamientos con LAG (Filtro temporal)
for tr = 1:length(track)
    x = track(tr).x;
    y = track(tr).y;

    % Si el track es más corto que el Lag, no sirve, se ignora
    if length(x) > Lag
        % Restamos la posición i con la posición i+Lag
        dx_temp = x(1+Lag:end) - x(1:end-Lag);
        dy_temp = y(1+Lag:end) - y(1:end-Lag);

        dx_lagged = [dx_lagged; dx_temp];
        dy_lagged = [dy_lagged; dy_temp];
    end
end

% Calcular ángulos filtrados
angulos_lag = atan2(dy_lagged, dx_lagged);

% --- VISUALIZACIÓN ---
figure(7), clf

% SUBPLOT 1: Rose Plot con Time Lag (Tu solución 2)
% Esto reduce el ruido porque los pasos pequeños se cancelan y los largos suman.
subplot(1,2,1)
h1 = polarhistogram(angulos_lag, 36);
title(sprintf('Rose Plot con Lag = %d frames', Lag))
h1.FaceColor = [0.2 0.6 0.8];
h1.EdgeColor = 'none';
h1.FaceAlpha = 0.7;


% SUBPLOT 2: Sustracción del "Círculo de Ruido" (Tu solución 1)
% Tomamos los datos del gráfico anterior y le restamos el ruido de fondo.
subplot(1,2,2)

% Obtenemos los conteos (bincounts) del histograma anterior
conteo_original = h1.BinCounts;
bordes = h1.BinEdges;
centros = (bordes(1:end-1) + bordes(2:end))/2;

% Calculamos el "piso de ruido".
% Asumimos que la dirección con MENOS flujo representa el ruido base isotrópico.
ruido_isotropico = min(conteo_original);

% Restamos ese círculo a todos (lo que queda es el exceso direccional puro)
conteo_rectificado = conteo_original - ruido_isotropico;

% Como polarhistogram a veces es mañoso para plotear conteos directos,
% usamos polarplot cerrando el círculo manualmente.
angulos_plot = [centros, centros(1)]; % Repetir el primero para cerrar
valores_plot = [conteo_rectificado, conteo_rectificado(1)];

polarplot(angulos_plot, valores_plot, 'LineWidth', 2, 'Color', [0.8 0.2 0.2])
hold on
% Rellenar el área para que se vea bonito
patch(transform_polar_x(angulos_plot, values_plot), ...
      transform_polar_y(angulos_plot, values_plot), ...
      [0.8 0.2 0.2], 'FaceAlpha', 0.5, 'EdgeColor', 'none');

% (Nota: Como patch en polar es complejo, una alternativa simple es:)
fill_polar(angulos_plot, valores_plot, [0.8500 0.3250 0.0980]);

title('Componente Anisotrópica (Ruido Restado)')
subtitle('Solo muestra el exceso de rectificación')

% Función auxiliar local para rellenar en polar (ponla al final del script o archivo)
function fill_polar(theta, rho, color)
    [x, y] = pol2cart(theta, rho);
    fill(x, y, color, 'FaceAlpha', 0.6, 'EdgeColor', 'r', 'LineWidth', 1.5);
    % Ajustar ejes para que parezca polar
    axis equal off
    % Dibujar círculos de grilla (opcional, para referencia)
    hold on
    max_val = max(rho);
    viscircles([0 0], max_val, 'Color', [0.9 0.9 0.9], 'LineWidth', 0.5);
end

%% guardar para hacer global con lag

% Guardamos las posiciones crudas. Esto nos da libertad total para
% elegir cualquier LAG después sin tener que volver a analizar el video.

% Extraemos X e Y de la estructura track a celdas
Raw_X = {track.x};
Raw_Y = {track.y};

% Definir nombre (ej. Datos_Raw_Video1.mat)
NombreMat = strrep(NombreArchivo, '.csv', '_RawTracks.mat');
