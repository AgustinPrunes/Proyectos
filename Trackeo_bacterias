%% Cargar datos
% Esta parte lee el archivo .csv que se exporta de Trackmate y guarda la
% información en una tabla.
% Modificar nombre del archivo 

clear
NombreArchivo='/MATLAB Drive/Sec_1_spots.csv';
tabla=readmatrix(NombreArchivo);
tabla=tabla(2:end,:);

%% Separar columnas relevantes
% Se leen solo las columnas que interesan de la tabla. En mi caso además de 
% posicion, tiempo y número de track también me interesaba la longitud y
% orientacion de las bacterias, pero eso lo puedes eliminar o comentar.

TrackID=tabla(:,3);
x=tabla(:,5);
y=tabla(:,6);
t=tabla(:,8);
Major=tabla(:,23);
Minor=tabla(:,24);
Theta=tabla(:,25);
AR=tabla(:,26);

%% Separar tracks
% Acá se separan los tracks y se guardan en la estructura track

tr=1;
for ii=0:max(TrackID)
    [~,orden]=sort(t(TrackID==ii));
    if isempty(orden)
        continue
    end
    xx=x(TrackID==ii); xx=xx(orden);
    yy=y(TrackID==ii); yy=yy(orden);
    tt=t(TrackID==ii); tt=tt(orden)+1;
    major=Major(TrackID==ii); major=major(orden);
    minor=Minor(TrackID==ii); minor=minor(orden);
    theta=Theta(TrackID==ii); theta=theta(orden);
    ar=AR(TrackID==ii); ar=ar(orden);
    track(tr).x=xx;
    track(tr).y=yy;
    track(tr).t=tt;
    track(tr).major=major;
    track(tr).minor=minor;
    track(tr).theta=theta;
    track(tr).ar=ar;
    tr=tr+1;
    duracion(tr)=length(xx);
end

