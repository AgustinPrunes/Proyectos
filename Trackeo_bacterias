%% Calcular Tercer Momento Global (Sin Toolbox)
clear
clc

% 1. Lista de tus archivos
archivos = {'Dx.mat', 'Dx2.mat', 'Dx3.mat'};

% 2. Variable donde acumularemos todos los datos
Datos_Totales = [];

% 3. Bucle para cargar y unir
for k = 1:length(archivos)
    if isfile(archivos{k})
        temp = load(archivos{k});

        % IMPORTANTE: Asegúrate de que el nombre aquí ('Dx_micras')
        % sea el mismo con el que guardaste. Si guardaste 'Dx', pon 'Dx'.
        if isfield(temp, 'Dx_micras')
            datos_nuevos = temp.Dx_micras;
        elseif isfield(temp, 'Dx') % Intento alternativo si Dx_micras no existe
            datos_nuevos = temp.Dx;
        else
            warning('No se encontró variable Dx o Dx_micras en %s', archivos{k});
            continue;
        end

        % Asegurar que sea vector fila para concatenar bien
        datos_nuevos = reshape(datos_nuevos, 1, []);
        Datos_Totales = [Datos_Totales, datos_nuevos];

        fprintf('Cargado %s: %d tracks añadidos.\n', archivos{k}, length(datos_nuevos));
    else
        fprintf('Cuidado: El archivo %s no existe.\n', archivos{k});
    end
end

%% 4. Cálculos Estadísticos MANUALES (Funciona sin Toolbox)

if ~isempty(Datos_Totales)

    % A) Media y Desviación Estándar
    Media_Global = mean(Datos_Totales);
    Desv_Std = std(Datos_Totales); % Desviación estándar
    N = length(Datos_Totales);

    % B) Tercer Momento Central (Numerador)
    % Promedio de las diferencias al cubo
    Momento3_Central = sum((Datos_Totales - Media_Global).^3) / N;

    % C) Asimetría (Skewness) - Adimensional
    % Fórmula: Momento 3 dividido por la desviación estándar al cubo
    % (Esta es la definición estándar de Fisher-Pearson)
    Asimetria_Global = Momento3_Central / (Desv_Std^3);

    % --- Mostrar Resultados ---
    fprintf('\n=========================================\n');
    fprintf('RESULTADOS COMBINADOS (N = %d tracks)\n', N);
    fprintf('=========================================\n');
    fprintf('Media Global (Rectificación Neta): %.4f micras\n', Media_Global);
    fprintf('-----------------------------------------\n');
    fprintf('SKEWNESS (Asimetría) GLOBAL:       %.4f\n', Asimetria_Global);
    fprintf('-----------------------------------------\n');

    if Asimetria_Global > 0
        disp('CONCLUSIÓN: El sistema rectifica preferentemente hacia la DERECHA (Positivo).');
    elseif Asimetria_Global < 0
        disp('CONCLUSIÓN: El sistema rectifica preferentemente hacia la IZQUIERDA (Negativo).');
    else
        disp('CONCLUSIÓN: Sistema simétrico (No rectifica).');
    end

    %% 5. Graficar
    figure(10), clf
    histogram(Datos_Totales, 'Normalization', 'probability', 'FaceColor', [0.6 0.2 0.8])
    hold on
    xline(Media_Global, '--r', 'LineWidth', 2)
    xline(0, '-k', 'LineWidth', 1)
    title(['Distribución Combinada (Skewness = ' num2str(Asimetria_Global, '%.3f') ')'])
