%% ANÁLISIS MAESTRO: Rose Plot + Curva de Eficiencia
clear
clc

% 1. Configuración de Archivos
archivos = {'Sec_1_spots_RawTracks.mat', 'Sec_1_t2_spots_RawTracks.mat', 'Sec_2_spots_RawTracks.mat'}; 

% Variable maestra para guardar TODAS las trayectorias crudas de todos los videos
% (Necesario para recalcular eficiencias con distintos lags después)
Master_X = {}; 
Master_Y = {};

%% 2. Carga y Consolidación de Datos Crudos
fprintf('Cargando archivos...\n');
for k = 1:length(archivos)
    if isfile(archivos{k})
        datos = load(archivos{k});
        if isfield(datos, 'Raw_X') && isfield(datos, 'Raw_Y')
            % Concatenar las celdas de este video a la lista maestra
            % (Aseguramos que sean columnas para evitar errores de dimensión)
            Master_X = [Master_X; datos.Raw_X(:)];
            Master_Y = [Master_Y; datos.Raw_Y(:)];
            fprintf(' -> %s: OK (%d tracks)\n', archivos{k}, length(datos.Raw_X));
        end
    else
        warning('Archivo %s no encontrado.', archivos{k});
    end
end
fprintf('Total de tracks cargados: %d\n', length(Master_X));

%% 3. Definir Lag y Calcular para el Rose Plot
Lag_Visual = 214; % Lag para el Rose Plot

Dx_Lagged = [];
Dy_Lagged = [];

for t = 1:length(Master_X)
    track_x = Master_X{t};
    track_y = Master_Y{t};
    
    if length(track_x) > Lag_Visual
        % Calcular desplazamientos con el Lag elegido
        dx = track_x(1+Lag_Visual:end) - track_x(1:end-Lag_Visual);
        dy = track_y(1+Lag_Visual:end) - track_y(1:end-Lag_Visual);
        Dx_Lagged = [Dx_Lagged; dx];
        Dy_Lagged = [Dy_Lagged; dy];
    end
end

% Graficar Rose Plot (Resumido)
figure(31), clf
subplot(1,2,1)
angulos = atan2(Dy_Lagged, Dx_Lagged);
polarhistogram(angulos, 36, 'FaceColor', [0.6 0.6 0.6], 'EdgeColor', 'none');
title(sprintf('Rose Plot (Lag = %d)', Lag_Visual));

%% 4. SECCIÓN NUEVA: Gráfico de Eficiencia vs. Lag
% Aquí calculamos cómo cambia la eficiencia si miramos ventanas de tiempo mayores.

Lags_Prueba = 1:250; % Probaremos del frame 1 al 20
Eficiencia_Curve = zeros(size(Lags_Prueba));

fprintf('\nCalculando curva de eficiencia...\n');

for k = 1:length(Lags_Prueba)
    this_lag = Lags_Prueba(k);
    
    Suma_Neta = 0;
    Suma_Absoluta = 0;
    
    % Recorremos todos los tracks con el lag actual "k"
    for t = 1:length(Master_X)
        tx = Master_X{t};
        if length(tx) > this_lag
            dx_temp = tx(1+this_lag:end) - tx(1:end-this_lag);
            
            Suma_Neta = Suma_Neta + sum(dx_temp);      % Cuánto avanzó (+ o -)
            Suma_Absoluta = Suma_Absoluta + sum(abs(dx_temp)); % Cuánto caminó
        end
    end
    
    % Calcular eficiencia para este Lag
    if Suma_Absoluta > 0
        Eficiencia_Curve(k) = Suma_Neta / Suma_Absoluta;
    else
        Eficiencia_Curve(k) = 0;
    end
end

%% 5. Visualizar la Curva de Eficiencia
subplot(1,2,2)

% Graficar línea
plot(Lags_Prueba, Eficiencia_Curve, 'o-', ...
    'LineWidth', 2, 'Color', [0.85 0.33 0.1], 'MarkerFaceColor', 'w');

hold on
yline(0, '--k', 'Alpha', 0.5); % Línea de cero para referencia
grid on

% Estética
xlabel('Time Lag (frames)');
ylabel('Eficiencia de Rectificación R_E');
title('Robustez de la Rectificación');
subtitle('¿Se mantiene la eficiencia en el tiempo?');

% Interpretar el resultado en el gráfico
Max_Ef = max(abs(Eficiencia_Curve));
ylim([-Max_Ef*1.2, Max_Ef*1.2]); % Centrar el 0

% Añadir un texto con el valor máximo alcanzado
[val_max, idx_max] = max(abs(Eficiencia_Curve));
signo = sign(Eficiencia_Curve(idx_max));
text(Lags_Prueba(idx_max), Eficiencia_Curve(idx_max), ...
    sprintf('  Máx: %.4f', val_max*signo), ...
    'FontWeight', 'bold');

print -dpdf Analisis_Completo_Eficiencia.pdf
