archivos = {'Sec_1_spots_RawTracks.mat', 'Sec_1_t2_spots_RawTracks.mat', 'Sec_2_spots_RawTracks.mat'}; 

Lag = 214; % <--- AQUÍ CAMBIAS EL LAG PARA TODOS LOS VIDEOS A LA VEZ
% Lag pequeño (1-3) = Más datos, pero más ruido.
% Lag grande (5-10) = Menos datos, pero ves el flujo real neto.

% Inicializar acumuladores globales
Dx_Global_Lag = [];
Dy_Global_Lag = [];

%% 2. Carga y Procesamiento
for k = 1:length(archivos)
    if isfile(archivos{k})
        datos = load(archivos{k});
        
