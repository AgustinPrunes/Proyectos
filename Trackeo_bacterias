            mis_Y = datos.Raw_Y;
            
            % Recorrer cada track de este archivo
            for t = 1:length(mis_X)
                track_x = mis_X{t};
                track_y = mis_Y{t};
                
                % Aplicar lógica de LAG
                if length(track_x) > Lag
                    % Posición futura - Posición actual
                    dx_t = track_x(1+Lag:end) - track_x(1:end-Lag);
                    dy_t = track_y(1+Lag:end) - track_y(1:end-Lag);
                    
                    % Acumular en la lista gigante
                    Dx_Global_Lag = [Dx_Global_Lag; dx_t(:)];
                    Dy_Global_Lag = [Dy_Global_Lag; dy_t(:)];
                end
            end
