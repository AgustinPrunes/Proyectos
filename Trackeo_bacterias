%% Graficar Contribución al Tercer Momento (Asimetría)
% Este gráfico muestra EXACTAMENTE qué velocidades están generando la rectificación.
% Eje Y positivo = Contribución al flujo hacia adelante (Rectificación).
% Eje Y negativo = Contribución al contra-flujo (Fugas).

% Recalcular datos necesarios
Dx_micras = Dx * calibracion;
