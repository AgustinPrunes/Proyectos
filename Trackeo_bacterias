%% Mapa de Flujo Espacial (Vector Field)
% Esta sección divide el espacio en una cuadrícula y calcula la dirección
% promedio de las bacterias en cada zona. Ayuda a ver cómo la geometría
% de la válvula Tesla afecta el flujo localmente.

% Parámetros de la cuadrícula (Grid)
bin_size = 32; % Tamaño del bin en píxeles (ajusta según resolución, e.g., 32, 64, 128)
X_edges = 1:bin_size:2048;
Y_edges = 1:bin_size:614;

% Inicializar matrices acumuladoras
SumVx = zeros(length(Y_edges)-1, length(X_edges)-1);
SumVy = zeros(length(Y_edges)-1, length(X_edges)-1);
Count = zeros(length(Y_edges)-1, length(X_edges)-1);

% Recorrer todos los tracks para llenar la cuadrícula
for tr = 1:length(track)
    % Obtener posiciones y diferencias
    this_x = track(tr).x;
    this_y = track(tr).y;
    
    % Calcular velocidades instantáneas (dx, dy) entre frames
    dx = diff(this_x);
    dy = diff(this_y);
    
    % Coordenadas para asignar al bin (usamos el punto medio del paso)
    mid_x = this_x(1:end-1) + dx/2;
    mid_y = this_y(1:end-1) + dy/2;
    
    % Discretizar posiciones (encontrar en qué casilla cae cada punto)
    [~, ~, x_bin] = histcounts(mid_x, X_edges);
    [~, ~, y_bin] = histcounts(mid_y, Y_edges);
    
    % Acumular vectores
    for k = 1:length(dx)
        if x_bin(k) > 0 && y_bin(k) > 0 % Verificar que esté dentro de los límites
            row = y_bin(k);
            col = x_bin(k);
            SumVx(row, col) = SumVx(row, col) + dx(k);
            SumVy(row, col) = SumVy(row, col) + dy(k);
            Count(row, col) = Count(row, col) + 1;
        end
    end
end

% Calcular promedios (evitar división por cero)
AvgVx = SumVx ./ Count;
AvgVy = SumVy ./ Count;
AvgVx(isnan(AvgVx)) = 0;
AvgVy(isnan(AvgVy)) = 0;

% Generar coordenadas para el gráfico (centros de los bins)
[X_centers, Y_centers] = meshgrid(...
    X_edges(1:end-1) + bin_size/2, ...
    Y_edges(1:end-1) + bin_size/2);

% --- GRAFICAR ---
figure(4), clf
hold on

% 1. Opcional: Dibujar un mapa de calor de "Ocupación" (dónde pasaron más tiempo)
% Esto te dice si las bacterias prefieren ciertas zonas de la válvula.
imagesc(X_edges, Y_edges, Count);
colormap(flipud(gray)); % Fondo gris claro donde hay menos datos
c = colorbar;
ylabel(c, 'Cantidad de pasos detectados')

% 2. Dibujar los vectores de flujo (Flechas)
% Scale = ajusta el tamaño de las flechas.
quiver(X_centers, Y_centers, AvgVx, AvgVy, 2.0, 'r', 'LineWidth', 1.5)

axis image
axis ij % Invertir eje Y para coincidir con imágenes estándar
axis([1, 2048, 1, 614])
title('Campo de Flujo Promedio en la Válvula')
xlabel('Posición X (px)')
ylabel('Posición Y (px)')

% Añadir leyenda explicativa
text(20, 40, 'Flecha Roja = Dirección Promedio', 'Color', 'r', 'FontWeight', 'bold')

print -dpdf Mapa_Flujo_Tesla.pdf
%% Distribución Angular (Rose Plot) y Eficiencia
% Este gráfico resume hacia dónde apuntan todas las bacterias en cada instante.
% Es la mejor forma visual de probar rectificación.

dx_all = [];
dy_all = [];

% Recopilar todos los movimientos instantáneos
for tr = 1:length(track)
    dx_inst = diff(track(tr).x,60); % cambio en x paso a paso
    dy_inst = diff(track(tr).y,60); % cambio en y paso a paso
    dx_all = [dx_all; dx_inst];
    dy_all = [dy_all; dy_inst];
end

% Calcular ángulos en radianes (-pi a pi)
angulos = atan2(dy_all, dx_all);

figure(5), clf
% Histograma polar con 36 divisiones (cada 10 grados)
p = polarhistogram(angulos, 36); 

title('Distribución de Direcciones de Movimiento')
% Estética para que se vea profesional
p.FaceColor = [0.2 0.5 0.9];
p.FaceAlpha = 0.6;
p.EdgeColor = 'none';
%
%
conteo_original = p.BinCounts;
bordes = p.BinEdges;
centros = (bordes(1:end-1) + bordes(2:end))/2;

% Calculamos el "piso de ruido".
% Asumimos que la dirección con MENOS flujo representa el ruido base isotrópico.

% ruido_isotropico = min(conteo_original);
ruido_isotropico = min(conteo_original);


% Restamos ese círculo a todos (lo que queda es el exceso direccional puro)
conteo_rectificado = conteo_original - ruido_isotropico;

% Como polarhistogram a veces es mañoso para plotear conteos directos,
% usamos polarplot cerrando el círculo manualmente.
angulos_plot = [centros, centros(1)]; % Repetir el primero para cerrar
valores_plot = [conteo_rectificado, conteo_rectificado(1)];

polarplot(angulos_plot, valores_plot, 'LineWidth', 2, 'Color', [0.8 0.2 0.2])
hold on

%% CÁLCULO DE EFICIENCIA 

% Suma neta (lo que avanzaron realmente hacia la derecha/izquierda)
desplazamiento_neto_x = sum(dx_all); 

% Suma absoluta (lo que caminaron en total, sin importar dirección)
distancia_total_x = sum(abs(dx_all)); 

% Coeficiente de Rectificación [-1 a 1]
% Valor positivo: Rectifica a la derecha. 
% Valor negativo: Rectifica a la izquierda.
% Cero: No rectifica (movimiento aleatorio).
rectificacion = desplazamiento_neto_x / distancia_total_x;

fprintf('------------------------------------------------\n');
fprintf('RESULTADOS DE LA VÁLVULA TESLA:\n');
fprintf('Coeficiente de Rectificación: %.4f\n', rectificacion);
if rectificacion > 0
    fprintf('Diagnóstico: Hay flujo preferencial hacia la DERECHA.\n');
elseif rectificacion < 0
    fprintf('Diagnóstico: Hay flujo preferencial hacia la IZQUIERDA.\n');
else
    fprintf('Diagnóstico: No hay rectificación observable.\n');
end
